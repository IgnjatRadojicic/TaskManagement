@page "/reset-password"
@layout PublicLayout
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<div class="auth-page">
    <img src="images/leaf-top-right.png" alt="" class="auth-leaf-tr" />
    <img src="images/leaf-bottom-left.png" alt="" class="auth-leaf-bl" />

    <MudCard Class="auth-card fade-in" Elevation="2">
        <MudCardContent>
            <div class="auth-logo-section">
                <img src="images/logo.png" alt="Plantitask" class="auth-logo" />
                <span class="text-sora auth-brand-text">PLANTITASK</span>
            </div>

            <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6"
                     Style="font-weight:700;">
                Set new password
            </MudText>

            <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <MudTextField Value="_model.NewPassword"
                              ValueChanged="@((string val) => { OnPasswordChanged(val); return Task.CompletedTask; })"
                              Label="New Password"
                              Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => { _showPassword = !_showPassword; })"
                              Required="true"
                              Class="mb-1"
                              Disabled="_loading"
                              Immediate="true" />

                <MudText Typo="Typo.caption" Style="color: #999;" Class="mb-2">
                    @_passwordRequirementsText
                </MudText>

                <div class="strength-bar mb-2">
                    <div class="strength-bar-fill"
                         style="width:@(_strengthPercent)%; background-color:@_strengthColor;">
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_strengthLabel))
                {
                    <MudText Typo="Typo.caption" Color="@_strengthMudColor" Class="mb-4">
                        Password strength: <strong>@_strengthLabel</strong>
                    </MudText>
                }

                <MudTextField @bind-Value="_confirmPassword"
                              Label="Confirm Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Required="true"
                              Class="mb-4"
                              Disabled="_loading" />

                @if (!string.IsNullOrEmpty(_confirmPassword) && _model.NewPassword != _confirmPassword)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="mb-4">
                        Passwords do not match
                    </MudText>
                }

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="@(_loading || !IsPasswordValid() || _model.NewPassword != _confirmPassword)"
                           Class="mb-4 auth-btn">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                             Color="Color.Surface" Class="mr-2" />
                    }
                    Reset Password
                </MudButton>
            </EditForm>

            <div class="auth-links">
                <MudLink Href="/login" Typo="Typo.body2">Back to login</MudLink>
            </div>
        </MudCardContent>
    </MudCard>
</div>

@code {
    private ResetPasswordRequest _model = new();
    private string _confirmPassword = string.Empty;
    private bool _loading;
    private bool _showPassword;
    private int _strengthPercent;
    private string _strengthColor = "#E0E0E0";
    private string _strengthLabel = string.Empty;
    private Color _strengthMudColor = Color.Default;
    private string _passwordRequirementsText = "Password must be at least 8 characters with uppercase, lowercase, number, and special character (@$!%*?&#)";

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _model.Token = query["token"] ?? string.Empty;
        _model.Email = query["email"] ?? string.Empty;

        if (string.IsNullOrEmpty(_model.Token) || string.IsNullOrEmpty(_model.Email))
        {
            Snackbar.Add("Invalid reset link", Severity.Error);
            Navigation.NavigateTo("/login");
        }
    }

    private async Task HandleSubmit()
    {
        if (_model.NewPassword != _confirmPassword)
            return;

        _loading = true;
        var result = await AuthService.ResetPasswordAsync(_model);
        _loading = false;

        if (result.Success)
        {
            Snackbar.Add("Password reset successfully. Please log in.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add(result.Error, Severity.Error);
        }
    }

    private void OnPasswordChanged(string password)
    {
        _model.NewPassword = password;
        CalculateStrength(password);
    }

    private void CalculateStrength(string password)
    {
        var score = 0;

        if (password.Length >= 8) score++;
        if (password.Any(char.IsUpper)) score++;
        if (password.Any(char.IsLower)) score++;
        if (password.Any(char.IsDigit)) score++;
        if (password.Any(c => "@$!%*?&#".Contains(c))) score++;

        (_strengthPercent, _strengthColor, _strengthLabel, _strengthMudColor) = score switch
        {
            0 => (0, "#E0E0E0", string.Empty, Color.Default),
            1 => (20, "#D32F2F", "Weak", Color.Error),
            2 => (40, "#F44336", "Fair", Color.Error),
            3 => (60, "#F9A825", "Good", Color.Warning),
            4 => (80, "#9CC103", "Strong", Color.Success),
            _ => (100, "#4CAF50", "Very strong", Color.Success),
        };
    }

    private bool IsPasswordValid()
    {
        return !string.IsNullOrEmpty(_model.NewPassword) &&
               _model.NewPassword.Length >= 8 &&
               _model.NewPassword.Any(char.IsUpper) &&
               _model.NewPassword.Any(char.IsLower) &&
               _model.NewPassword.Any(char.IsDigit) &&
               _model.NewPassword.Any(c => "@$!%*?&#".Contains(c));
    }
}
