@page "/forgot-password"
@layout PublicLayout
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<div class="auth-page">
    <img src="images/leaf-top-right.png" alt="" class="auth-leaf-tr" />
    <img src="images/leaf-bottom-left.png" alt="" class="auth-leaf-bl" />

    <MudCard Class="auth-card fade-in" Elevation="2">
        <MudCardContent>
            <div class="auth-logo-section">
                <img src="images/logo.png" alt="Plantitask" class="auth-logo" />
                <span class="text-sora auth-brand-text">PLANTITASK</span>
            </div>

            @if (!_sent)
            {
                <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-2"
                         Style="font-weight:700;">
                    Reset your password
                </MudText>

                <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-6"
                         Color="Color.Secondary">
                    Enter your email and we will send you a reset link.
                </MudText>

                <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="_model.Email"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Required="true"
                                  Class="mb-4"
                                  Disabled="_loading" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="_loading"
                               Class="mb-4 auth-btn">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                 Color="Color.Surface" Class="mr-2" />
                        }
                        Send Reset Link
                    </MudButton>
                </EditForm>
            }
            else
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                    If an account with that email exists, a reset link has been sent.
                </MudAlert>
            }

            <div class="auth-links">
                <MudLink Href="/login" Typo="Typo.body2">Back to login</MudLink>
            </div>
        </MudCardContent>
    </MudCard>
</div>

@code {
    private ForgotPasswordRequest _model = new();
    private bool _loading;
    private bool _sent;

    private async Task HandleSubmit()
    {
        _loading = true;
        await AuthService.ForgotPasswordAsync(_model.Email);
        _loading = false;

        _sent = true;
    }
}