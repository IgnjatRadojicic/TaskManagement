@inject IUserProfileService ProfileService
@inject ISnackbar Snackbar

<div class="ds-card">
    <div class="ds-card-header">
        <h2 class="text-sora">Password &amp; Authentication</h2>
    </div>
    @if (!_showForm)
    {
        <button class="ds-btn-primary" @onclick="() => _showForm = true">
            Change Password
        </button>
    }
    else
    {
        <div class="ds-password-form">
            <div class="ds-field">
                <label class="ds-field-label">CURRENT PASSWORD</label>
                <input class="ds-field-input" type="password" @bind="_currentPassword" />
            </div>
            <div class="ds-field">
                <label class="ds-field-label">NEW PASSWORD</label>
                <input class="ds-field-input" type="password" @bind="_newPassword" />
            </div>
            <div class="ds-field">
                <label class="ds-field-label">CONFIRM NEW PASSWORD</label>
                <input class="ds-field-input" type="password" @bind="_confirmPassword" />
            </div>
            <div class="ds-password-actions">
                <button class="ds-btn-text" @onclick="Cancel">Cancel</button>
                <button class="ds-btn-primary" @onclick="Submit" disabled="@_submitting">
                    @if (_submitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                             Color="Color.Inherit" Style="width:16px;height:16px;" />
                    }
                    else
                    {
                        <span>Change Password</span>
                    }
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool _showForm;
    private bool _submitting;
    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 8)
        {
            Snackbar.Add("Password must be at least 8 characters", Severity.Warning);
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("Passwords do not match", Severity.Warning);
            return;
        }

        _submitting = true;
        StateHasChanged();

        var model = new ChangePasswordDto
        {
            CurrentPassword = _currentPassword,
            NewPassword = _newPassword,
            ConfirmNewPassword = _confirmPassword
        };

        var result = await ProfileService.ChangePasswordAsync(model);

        if (result.Success)
        {
            Cancel();
            Snackbar.Add("Password changed successfully", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Error, Severity.Error);
        }

        _submitting = false;
        StateHasChanged();
    }

    private void Cancel()
    {
        _showForm = false;
        _currentPassword = _newPassword = _confirmPassword = "";
    }
}
